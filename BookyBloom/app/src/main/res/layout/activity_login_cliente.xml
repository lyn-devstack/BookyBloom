<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Cliente.Login_Cliente"
    android:background="@color/coral">

    <!--Toolbar-->
    <RelativeLayout
        android:id="@+id/toolbarRLClienteLogin"
        android:layout_width="match_parent"
        android:layout_height="@dimen/m_toolbar_height"
        android:background="@color/white">

        <ImageButton
            android:id="@+id/Ib_regresar"
            android:src="@drawable/ic_regresar"
            android:padding="15dp"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/TxtLoginCliente"
            android:textColor="@color/coral"
            android:textStyle="bold"/>

        <View
            android:background="#ccc"
            android:layout_alignParentBottom="true"
            android:layout_width="match_parent"
            android:layout_height="1dp" />

    </RelativeLayout>

    <!-- Credenciales -->
    <RelativeLayout
        android:layout_below="@+id/toolbarRLClienteLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!--Email-->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                android:background="@color/pastelgreen">

                <EditText
                    android:id="@+id/Et_email_cl"
                    android:hint="@string/Et_email_cl"
                    android:inputType="textEmailAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>


            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:passwordToggleEnabled="true"
                android:background="@color/pastelgreen">

                <EditText
                    android:id="@+id/Et_password_cl"
                    android:hint="@string/Et_password_cl"
                    android:inputType="textPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>


            </com.google.android.material.textfield.TextInputLayout>

            <!-- Boton iniciar con correo electronico-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/Btn_login_cliente"
                android:text="@string/Btn_login_cliente"
                android:layout_gravity="center"
                android:layout_marginTop="15dp"
                android:textAllCaps="true"
                android:layout_width="250dp"
                android:layout_height="wrap_content" />
            
            <View
                android:layout_marginTop="10dp"
                android:background="#cccccc"
                android:layout_width="match_parent"
                android:layout_height="1dp"/>

            <TextView
                android:text="@string/Txt_alternativa"
                android:layout_gravity="center"
                android:layout_marginTop="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Boton iniciar con Google -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/Btn_login_google"
                android:text="@string/Btn_login_google"
                android:textAllCaps="true"
                android:layout_gravity="center"
                app:icon="@drawable/icono_google"
                android:layout_marginTop="10dp"
                android:layout_width="250dp"
                android:layout_height="wrap_content"/>

        </androidx.appcompat.widget.LinearLayoutCompat>

    </RelativeLayout>

</RelativeLayout>